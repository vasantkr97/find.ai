OPENAI_API_KEY=sk-...
SERPER_API_KEY=...
DATABASE_URL=postgresql://query_agent:query_agent@localhost:5433/query_agent

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8081/api/drive/callback
NEXT_PUBLIC_APP_URL=http://localhost:3001

LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=100

AGENT_MAX_STEPS=10
AGENT_STEP_TIMEOUT_MS=30000
AGENT_LLM_RETRY_ATTEMPTS=3

VECTOR_SIMILARITY_THRESHOLD=0.3
VECTOR_DEFAULT_TOP_K=5
VECTOR_CHUNK_SIZE=1000
VECTOR_CHUNK_OVERLAP=200

RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

WEB_SCRAPE_TIMEOUT_MS=15000
WEB_SCRAPE_MAX_LENGTH=8000

NODE_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:3001
